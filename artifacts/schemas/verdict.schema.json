{
  "$id": "https://neuron7xlab.github.io/bsff/schemas/verdict.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "caveats": {
      "type": "array"
    },
    "claim_id": {
      "type": "string"
    },
    "evidence": {
      "type": "object"
    },
    "leakage_flags": {
      "type": "object"
    },
    "original_statistic": {
      "type": [
        "number",
        "null"
      ]
    },
    "p_value": {
      "type": [
        "number",
        "null"
      ]
    },
    "surrogate_max": {
      "type": [
        "number",
        "null"
      ]
    },
    "surrogate_min": {
      "type": [
        "number",
        "null"
      ]
    },
    "verdict": {
      "enum": [
        "REFUTED",
        "UNSUPPORTED",
        "SURVIVED"
      ],
      "type": "string"
    }
  },
  "required": [
    "claim_id",
    "verdict",
    "p_value",
    "original_statistic",
    "surrogate_min",
    "surrogate_max",
    "leakage_flags",
    "evidence",
    "caveats"
  ],
  "title": "BSFF VerdictJSON",
  "type": "object"
}
