{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neuron7xlab.github.io/bsff/schemas/openai_2026_eval.schema.json",
  "title": "OpenAI-2026 Eval Contract",
  "description": "Formal evaluation contract for the OpenAI-2026 Validation Grid (INTERNAL OpenAI-grade research-validation target, NOT an external OpenAI certification). Every eval is task -> inputs -> expected behaviour -> machine grader -> threshold -> failure mode -> evidence artifact -> result analysis. A grader is executable: it reads a real artifact and compares a metric against a threshold. No eval may PASS without a resolvable evidence_artifact and a satisfied grader.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_id", "grid_version", "evals"],
  "properties": {
    "contract_id": { "type": "string", "minLength": 1 },
    "grid_version": { "type": "string", "pattern": "^[0-9]{4}\\.[0-9]+$" },
    "description": { "type": "string" },
    "evals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "risk_class",
          "task_definition",
          "test_inputs",
          "ground_truth_or_expected_behavior",
          "grader",
          "threshold",
          "failure_mode",
          "evidence_artifact",
          "result_analysis"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "risk_class": {
            "enum": ["correctness", "false_positive", "false_negative", "robustness", "reproducibility", "claim_safety", "supply_chain"]
          },
          "task_definition": { "type": "string", "minLength": 8 },
          "test_inputs": { "type": "string", "minLength": 3 },
          "ground_truth_or_expected_behavior": { "type": "string", "minLength": 3 },
          "grader": {
            "type": "object",
            "additionalProperties": false,
            "required": ["artifact", "metric", "op"],
            "properties": {
              "artifact": { "type": "string", "minLength": 3 },
              "metric": { "type": "string", "minLength": 1 },
              "op": { "enum": ["ge", "le", "eq", "eq_field", "is_true", "len_ge"] },
              "value": {},
              "field": { "type": "string" }
            },
            "allOf": [
              {
                "if": { "properties": { "op": { "enum": ["ge", "le", "eq", "len_ge"] } } },
                "then": { "required": ["value"] }
              },
              {
                "if": { "properties": { "op": { "const": "eq_field" } } },
                "then": { "required": ["field"] }
              }
            ]
          },
          "threshold": { "type": "string", "minLength": 1 },
          "failure_mode": { "type": "string", "minLength": 3 },
          "evidence_artifact": { "type": "string", "minLength": 3 },
          "result_analysis": { "type": "string", "minLength": 8 }
        }
      }
    }
  }
}
